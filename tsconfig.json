{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2020"
  },
  "include": ["src/ts/**/*.ts", "test/**/*.ts"],
  "references": [
    { "path": "./src/ts" }
  ]
}
